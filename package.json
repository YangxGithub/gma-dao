{
  "name": "gma-vue3-monorepo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build --mode development",
    "build:prod": "vite build --mode production",
    "preview": "vite preview --mode development --outDir gma-dao-dev",
    "preview:prod": "vite preview --mode production --outDir gma-dao-prod",
    "preview:spa": "node scripts/preview-spa.mjs --mode development --outDir gma-dao-dev",
    "preview:spa:prod": "node scripts/preview-spa.mjs --mode production --outDir gma-dao-prod"
  },
  "dependencies": {
    "pinia": "^3.0.4",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "sass-embedded": "^1.98.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
