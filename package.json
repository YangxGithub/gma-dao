{
  "name": "gma-vue3-monorepo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build --mode development && node scripts/zip-out.mjs development",
    "build:prod": "vite build --mode production && node scripts/zip-out.mjs production",
    "demo": "serve -l 5180 public/demo",
    "preview": "node scripts/preview-spa.mjs --mode development --outDir gma-dao-dev",
    "preview:prod": "node scripts/preview-spa.mjs --mode production --outDir gma-dao-prod"
  },
  "dependencies": {
    "ant-design-vue": "^4.2.6",
    "pinia": "^3.0.4",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "archiver": "^7.0.1",
    "sass-embedded": "^1.98.0",
    "serve": "^14.2.6",
    "typescript": "^5.6.0",
    "unplugin-vue-components": "^31.0.0",
    "vite": "^6.0.0"
  }
}
